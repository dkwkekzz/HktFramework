{
  "storyTag": "Story.Flow.Spawner.Item.ThunderHammer",
  "cancelOnDuplicate": false,
  "tags": {
    "ItemThunderHammer": "Entity.Item.ThunderHammer",
    "TagThunderHammer": "Entity.Attr.Item.ThunderHammer",
    "TagSkillLightning": "Entity.Attr.Skill.Lightning",
    "StanceSword1H": "Entity.Stance.Sword1H",
    "SkillRef": "Story.Event.Combat.UseSkill"
  },
  "steps": [
    { "op": "Log", "message": "ThunderHammer spawner: activated" },

    { "op": "Label", "name": "loop" },
    { "op": "HasPlayerInGroup", "dst": "Flag" },
    { "op": "JumpIfNot", "cond": "Flag", "label": "wait" },
    { "op": "CountByTag", "dst": "R0", "tag": "Entity.Attr.Item.ThunderHammer" },
    { "op": "LoadConst", "dst": "R1", "value": 1 },
    { "op": "CmpGe", "dst": "Flag", "src1": "R0", "src2": "R1" },
    { "op": "JumpIf", "cond": "Flag", "label": "wait" },

    { "op": "Log", "message": "[Snippet] SpawnGroundItem" },
    { "op": "SpawnEntity", "classTag": "Entity.Item.ThunderHammer" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 203 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "CopyPosition", "dst": "Spawned", "src": "Self" },

    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackPower", "value": 12 },
    { "op": "SetItemSkillTag", "entity": "Spawned", "skillTag": "Story.Event.Combat.UseSkill" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillCPCost", "value": 60 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "RecoveryFrame", "value": 100 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillTargetRequired", "value": 1 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackRange", "value": 500 },
    { "op": "SetStance", "entity": "Spawned", "stanceTag": "Entity.Stance.Sword1H" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.ThunderHammer" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Skill.Lightning" },

    { "op": "Log", "message": "ThunderHammer: item spawned" },

    { "op": "Label", "name": "wait" },
    { "op": "WaitSeconds", "seconds": 60.0 },
    { "op": "Jump", "label": "loop" }
  ]
}
