{
  "storyTag": "Story.State.Player.Init",
  "cancelOnDuplicate": false,
  "tags": {
    "EntityPlayer":      "Entity.Character.Player",
    "EntityItem":        "Entity.Item",
    "EntityWoodenSword": "Entity.Item.WoodenSword",
    "TagWeaponSword":    "Entity.Attr.Weapon.Sword",
    "StanceUnarmed":     "Entity.Stance.Unarmed",
    "StanceSword1H":     "Entity.Stance.Sword1H",
    "UseSkillTag":       "Story.Event.Combat.UseSkill",
    "VfxSpawnEffect":    "VFX.Niagara.SpawnEffect",
    "SndSpawn":          "Sound.Spawn"
  },
  "steps": [
    { "op": "Log", "message": "PlayerInit: 캐릭터 생성" },

    { "op": "SpawnEntity", "classTag": "EntityPlayer" },
    { "op": "Move", "dst": "Self", "src": "Spawned" },

    { "op": "LoadStore", "dst": "R1", "property": "TargetPosX" },
    { "op": "LoadStore", "dst": "R2", "property": "TargetPosY" },
    { "op": "LoadStore", "dst": "R3", "property": "TargetPosZ" },
    { "op": "SetPosition", "entity": "Self", "src": "R1" },

    { "op": "PlayVFXAttached", "entity": "Self", "tag": "VfxSpawnEffect" },
    { "op": "PlaySound", "tag": "SndSpawn" },

    { "op": "SetStance", "entity": "Self", "stanceTag": "StanceUnarmed" },
    { "op": "SaveConstEntity", "entity": "Self", "property": "BagCapacity",     "value": 8 },
    { "op": "SaveConstEntity", "entity": "Self", "property": "MaxCP",           "value": 100 },
    { "op": "SaveConstEntity", "entity": "Self", "property": "CP",              "value": 0 },
    { "op": "SaveConstEntity", "entity": "Self", "property": "AttackSpeed",     "value": 100 },
    { "op": "SaveConstEntity", "entity": "Self", "property": "NextActionFrame", "value": 0 },

    { "op": "CountByOwner", "dst": "R0", "owner": "Self", "tag": "EntityItem" },
    { "op": "CmpNeConst", "dst": "Flag", "src": "R0", "value": 0 },
    { "op": "JumpIf", "cond": "Flag", "label": "skip_grant" },

    { "op": "Log", "message": "PlayerInit: 목검 지급" },
    { "op": "SpawnEntity", "classTag": "EntityWoodenSword" },

    { "op": "SnippetAssignOwnership", "entity": "Spawned", "owner": "Self" },

    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "ItemState",     "value": 2 },
    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "ItemId",        "value": 100 },
    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "EquipIndex",    "value": 0 },
    { "op": "SaveEntityProperty","entity": "Self",    "property": "EquipSlot0",    "src":   "Spawned" },
    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "AttackPower",   "value": 5 },
    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "Equippable",    "value": 1 },
    { "op": "SetStance",         "entity": "Spawned", "stanceTag": "StanceSword1H" },
    { "op": "AddTag",            "entity": "Spawned", "tag": "TagWeaponSword" },
    { "op": "SetItemSkillTag",   "entity": "Spawned", "skillTag": "UseSkillTag" },
    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "SkillCPCost",   "value": 30 },
    { "op": "SaveConstEntity",   "entity": "Spawned", "property": "RecoveryFrame", "value": 60 },

    { "op": "SnippetApplyItemStats", "item": "Spawned", "character": "Self" },

    { "op": "Label", "name": "skip_grant" },
    { "op": "Log", "message": "PlayerInit: 준비 완료" },
    { "op": "Halt" }
  ]
}
