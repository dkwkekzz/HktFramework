{
  "storyTag": "Story.Event.Skill.Lightning",
  "tags": {
    "AnimCastLightning": "Anim.UpperBody.Cast.Lightning",
    "SndThunderStrike": "Sound.ThunderStrike",
    "SndThunderExplosion": "Sound.ThunderExplosion",
    "VfxLightningStrike": "VFX.Niagara.LightningStrike",
    "VfxLightningExplosion": "VFX.Niagara.LightningExplosion",
    "EffectShock": "Effect.Shock",
    "StateDead": "State.Dead"
  },
  "steps": [
    {"op": "GetWorldTime", "dst": "R0"},
    {"op": "LoadConst", "dst": "R1", "value": 35},
    {"op": "LoadConst", "dst": "R2", "value": 100},
    {"op": "Mul", "dst": "R1", "src1": "R1", "src2": "R2"},
    {"op": "LoadStore", "dst": "R2", "property": "AttackSpeed"},
    {"op": "Div", "dst": "R1", "src1": "R1", "src2": "R2"},
    {"op": "Add", "dst": "R0", "src1": "R0", "src2": "R1"},
    {"op": "SaveStore", "property": "NextActionFrame", "src": "R0"},
    {"op": "LoadConst", "dst": "R0", "value": 30},
    {"op": "LoadStore", "dst": "R1", "property": "AttackSpeed"},
    {"op": "Mul", "dst": "R0", "src1": "R0", "src2": "R1"},
    {"op": "LoadConst", "dst": "R1", "value": 35},
    {"op": "Div", "dst": "R0", "src1": "R0", "src2": "R1"},
    {"op": "SaveStore", "property": "MotionPlayRate", "src": "R0"},

    {"op": "Log", "message": "Lightning: 시전 시작"},
    {"op": "AddTag", "entity": "Self", "tag": "AnimCastLightning"},
    {"op": "WaitSeconds", "seconds": 0.6},

    {"op": "GetPosition", "dst": "R0", "entity": "Target"},
    {"op": "PlayVFX", "pos": "R0", "tag": "VfxLightningStrike"},
    {"op": "PlaySoundAtLocation", "pos": "R0", "tag": "SndThunderStrike"},

    {"op": "ApplyDamageConst", "target": "Target", "amount": 80},
    {"op": "PlayVFXAttached", "entity": "Target", "tag": "VfxLightningExplosion"},

    {"op": "IfPropertyLe", "entity": "Target", "property": "Health", "value": 0},
      {"op": "AddTag", "entity": "Target", "tag": "StateDead"},
    {"op": "EndIf"},

    {"op": "ForEachInRadius", "center": "Target", "radius": 200},
      {"op": "Move", "dst": "Target", "src": "Iter"},
      {"op": "ApplyDamageConst", "target": "Target", "amount": 30},
      {"op": "ApplyEffect", "target": "Target", "effectTag": "EffectShock"},
    {"op": "EndForEach"},

    {"op": "RemoveTag", "entity": "Self", "tag": "AnimCastLightning"},
    {"op": "Log", "message": "Lightning: 완료"},
    {"op": "Halt"}
  ]
}
