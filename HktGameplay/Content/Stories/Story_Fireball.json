{
  "storyTag": "Story.Event.Skill.Fireball",
  "tags": {
    "AnimCastFireball": "Anim.UpperBody.Cast.Fireball",
    "EntityFireball": "Entity.Projectile.Fireball",
    "SndLaunch": "Sound.FireballLaunch",
    "SndExplosion": "Sound.Explosion",
    "VfxDirectHit": "VFX.Niagara.DirectHit",
    "VfxExplosion": "VFX.Niagara.FireballExplosion",
    "EffectBurn": "Effect.Burn",
    "StateDead": "State.Dead"
  },
  "steps": [
    {"op": "GetWorldTime", "dst": "R0"},
    {"op": "LoadConst", "dst": "R1", "value": 45},
    {"op": "LoadConst", "dst": "R2", "value": 100},
    {"op": "Mul", "dst": "R1", "src1": "R1", "src2": "R2"},
    {"op": "LoadStore", "dst": "R2", "property": "AttackSpeed"},
    {"op": "Div", "dst": "R1", "src1": "R1", "src2": "R2"},
    {"op": "Add", "dst": "R0", "src1": "R0", "src2": "R1"},
    {"op": "SaveStore", "property": "NextActionFrame", "src": "R0"},
    {"op": "LoadConst", "dst": "R0", "value": 30},
    {"op": "LoadStore", "dst": "R1", "property": "AttackSpeed"},
    {"op": "Mul", "dst": "R0", "src1": "R0", "src2": "R1"},
    {"op": "LoadConst", "dst": "R1", "value": 45},
    {"op": "Div", "dst": "R0", "src1": "R0", "src2": "R1"},
    {"op": "SaveStore", "property": "MotionPlayRate", "src": "R0"},

    {"op": "Log", "message": "Fireball: 시전 시작"},
    {"op": "AddTag", "entity": "Self", "tag": "AnimCastFireball"},
    {"op": "WaitSeconds", "seconds": 1.0},

    {"op": "Log", "message": "Fireball: 투사체 생성"},
    {"op": "SpawnEntity", "classTag": "EntityFireball"},
    {"op": "CopyPosition", "dst": "Spawned", "src": "Self"},
    {"op": "MoveForward", "entity": "Spawned", "force": 500},
    {"op": "PlaySound", "tag": "SndLaunch"},

    {"op": "Log", "message": "Fireball: 충돌 대기 중..."},
    {"op": "WaitCollision", "entity": "Spawned"},

    {"op": "Log", "message": "Fireball: 충돌! 폭발 처리"},
    {"op": "GetPosition", "dst": "R0", "entity": "Spawned"},
    {"op": "DestroyEntity", "entity": "Spawned"},
    {"op": "ApplyDamageConst", "target": "Hit", "amount": 100},
    {"op": "PlayVFXAttached", "entity": "Hit", "tag": "VfxDirectHit"},

    {"op": "IfPropertyLe", "entity": "Hit", "property": "Health", "value": 0},
      {"op": "AddTag", "entity": "Hit", "tag": "StateDead"},
    {"op": "EndIf"},

    {"op": "PlayVFX", "pos": "R0", "tag": "VfxExplosion"},
    {"op": "PlaySoundAtLocation", "pos": "R0", "tag": "SndExplosion"},

    {"op": "Log", "message": "Fireball: 범위 피해 적용"},
    {"op": "ForEachInRadius", "center": "Hit", "radius": 300},
      {"op": "Move", "dst": "Target", "src": "Iter"},
      {"op": "ApplyDamageConst", "target": "Target", "amount": 50},
      {"op": "ApplyEffect", "target": "Target", "effectTag": "EffectBurn"},
      {"op": "IfPropertyLe", "entity": "Target", "property": "Health", "value": 0},
        {"op": "AddTag", "entity": "Target", "tag": "StateDead"},
      {"op": "EndIf"},
    {"op": "EndForEach"},

    {"op": "RemoveTag", "entity": "Self", "tag": "AnimCastFireball"},
    {"op": "Log", "message": "Fireball: 완료"},
    {"op": "Halt"}
  ]
}
