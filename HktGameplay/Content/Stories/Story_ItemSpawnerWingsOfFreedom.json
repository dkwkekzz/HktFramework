{
  "storyTag": "Story.Flow.Spawner.Item.WingsOfFreedom",
  "cancelOnDuplicate": false,
  "tags": {
    "ItemWingsOfFreedom": "Entity.Item.WingsOfFreedom",
    "TagWingsOfFreedom": "Entity.Attr.Item.WingsOfFreedom",
    "TagSkillBuff": "Entity.Attr.Skill.Buff",
    "SkillRef": "Story.Event.Combat.UseSkill"
  },
  "steps": [
    { "op": "Log", "message": "WingsOfFreedom spawner: activated" },

    { "op": "Label", "name": "loop" },
    { "op": "HasPlayerInGroup", "dst": "Flag" },
    { "op": "JumpIfNot", "cond": "Flag", "label": "wait" },
    { "op": "CountByTag", "dst": "R0", "tag": "Entity.Attr.Item.WingsOfFreedom" },
    { "op": "LoadConst", "dst": "R1", "value": 1 },
    { "op": "CmpGe", "dst": "Flag", "src1": "R0", "src2": "R1" },
    { "op": "JumpIf", "cond": "Flag", "label": "wait" },

    { "op": "Log", "message": "[Snippet] SpawnGroundItem" },
    { "op": "SpawnEntity", "classTag": "Entity.Item.WingsOfFreedom" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 204 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "CopyPosition", "dst": "Spawned", "src": "Self" },

    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackPower", "value": 0 },
    { "op": "SetItemSkillTag", "entity": "Spawned", "skillTag": "Story.Event.Combat.UseSkill" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillCPCost", "value": 30 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "RecoveryFrame", "value": 150 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillTargetRequired", "value": 0 },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.WingsOfFreedom" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Skill.Buff" },

    { "op": "Log", "message": "WingsOfFreedom: item spawned" },

    { "op": "Label", "name": "wait" },
    { "op": "WaitSeconds", "seconds": 60.0 },
    { "op": "Jump", "label": "loop" }
  ]
}
