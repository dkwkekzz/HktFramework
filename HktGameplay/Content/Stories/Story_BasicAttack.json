{
  "schema": 2,
  "storyTag": "Story.Event.Attack.Basic",
  "tags": {
    "AnimAttack": "Anim.Montage.Attack",
    "AnimHitReaction": "Anim.Montage.HitReaction",
    "StateDead": "State.Dead",
    "VfxHitSpark": "VFX.Niagara.HitSpark",
    "SndSwing": "Sound.Swing",
    "SndHit": "Sound.Hit"
  },
  "steps": [
    { "op": "GetWorldTime", "dst": {"var":"now"} },
    { "op": "LoadConst",    "dst": {"var":"recovery"}, "value": 20 },
    { "op": "LoadConst",    "dst": {"var":"hundred"},  "value": 100 },
    { "op": "Mul",          "dst": {"var":"recovery"}, "src1": {"var":"recovery"}, "src2": {"var":"hundred"} },
    { "op": "LoadStore",    "dst": {"var":"speed"},    "property": "AttackSpeed" },
    { "op": "Div",          "dst": {"var":"recovery"}, "src1": {"var":"recovery"}, "src2": {"var":"speed"} },
    { "op": "Add",          "dst": {"var":"now"},      "src1": {"var":"now"},      "src2": {"var":"recovery"} },
    { "op": "SaveStore",    "property": "NextActionFrame", "src": {"var":"now"} },

    { "op": "LoadConst",    "dst": {"var":"rateNum"},  "value": 30 },
    { "op": "LoadStore",    "dst": {"var":"rateDen"},  "property": "AttackSpeed" },
    { "op": "Mul",          "dst": {"var":"rateNum"},  "src1": {"var":"rateNum"}, "src2": {"var":"rateDen"} },
    { "op": "LoadConst",    "dst": {"var":"rateDen"},  "value": 20 },
    { "op": "Div",          "dst": {"var":"rateNum"},  "src1": {"var":"rateNum"}, "src2": {"var":"rateDen"} },
    { "op": "SaveStore",    "property": "MotionPlayRate", "src": {"var":"rateNum"} },

    { "op": "LookAt",   "entity": "Self",   "target": "Target" },
    { "op": "PlaySound", "tag": "SndSwing" },
    { "op": "PlayAnim", "entity": "Self",   "tag": "AnimAttack" },
    { "op": "ReadProperty", "dst": {"var":"atk"}, "property": "AttackPower" },

    { "op": "InteractTerrain", "center": "Self", "radius": 200 },

    { "op": "ForEachInRadius", "center": "Self", "radius": 200 },
      { "op": "IfNe", "a": "Iter", "b": "Self" },
        { "op": "IfHasTrait", "entity": "Iter", "trait": "Hittable" },
          { "op": "Move",       "dst": "Target", "src": "Iter" },
          { "op": "ApplyDamage", "target": "Target", "amount": {"var":"atk"} },
          { "op": "PlayVFXAtEntity", "entity": "Target", "tag": "VfxHitSpark" },
          { "op": "PlayAnim",   "entity": "Target", "tag": "AnimHitReaction" },
          { "op": "IfPropertyLe", "entity": "Target", "property": "Health", "value": 0 },
            { "op": "AddTag", "entity": "Target", "tag": "StateDead" },
          { "op": "EndIf" },
        { "op": "EndIf" },
      { "op": "EndIf" },
    { "op": "EndForEach" },

    { "op": "WaitAnimEnd", "entity": "Self" },
    { "op": "Log", "message": "BasicAttack: 완료" },
    { "op": "Halt" }
  ]
}
