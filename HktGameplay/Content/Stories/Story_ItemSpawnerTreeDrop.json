{
  "storyTag": "Story.Flow.Spawner.Item.TreeDrop",
  "cancelOnDuplicate": false,
  "tags": {
    "ItemWood": "Entity.Item.Wood",
    "TagMaterial": "Entity.Attr.Item.Material",
    "TagWood": "Entity.Attr.Item.Wood"
  },
  "steps": [
    { "op": "Log", "message": "TreeDrop spawner: activated" },

    { "op": "Label", "name": "loop" },
    { "op": "HasPlayerInGroup", "dst": "Flag" },
    { "op": "JumpIfNot", "cond": "Flag", "label": "wait" },
    { "op": "CountByTag", "dst": "R0", "tag": "Entity.Attr.Item.Wood" },
    { "op": "LoadConst", "dst": "R1", "value": 10 },
    { "op": "CmpGe", "dst": "Flag", "src1": "R0", "src2": "R1" },
    { "op": "JumpIf", "cond": "Flag", "label": "wait" },

    { "op": "SpawnEntity", "classTag": "Entity.Item.Wood" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 101 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.Material" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.Wood" },

    { "op": "ReadProperty", "dst": "R2", "property": "Param0" },
    { "op": "ReadProperty", "dst": "R3", "property": "Param1" },
    { "op": "LoadConst", "dst": "R4", "value": 0 },
    { "op": "SetPosition", "entity": "Spawned", "src": "R2" },

    { "op": "Log", "message": "TreeDrop: wood spawned" },

    { "op": "Label", "name": "wait" },
    { "op": "WaitSeconds", "seconds": 30.0 },
    { "op": "Jump", "label": "loop" }
  ]
}
