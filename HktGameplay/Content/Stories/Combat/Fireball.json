{
  "schema": 2,
  "storyTag": "Story.V2.Event.Skill.Fireball",
  "tags": {
    "AnimCast":     "Anim.UpperBody.Cast.Fireball",
    "ProjFireball": "Entity.Projectile.Fireball",
    "SoundLaunch":  "Sound.FireballLaunch",
    "SoundExplode": "Sound.Explosion",
    "VFXHit":       "VFX.Niagara.DirectHit",
    "VFXExplode":   "VFX.Niagara.FireballExplosion",
    "EffectBurn":   "Effect.Burn",
    "StateDead":    "State.Dead"
  },
  "steps": [
    { "op": "SnippetCooldownUpdateConst", "recoveryFrame": 45 },

    { "op": "AddTag",      "entity": {"self": true}, "tag": "AnimCast" },
    { "op": "WaitSeconds", "seconds": 1.0 },

    { "op": "Log", "message": "Fireball: 투사체 생성" },
    { "op": "SpawnEntity", "classTag": "ProjFireball", "out": "fireball" },
    { "op": "SaveConstEntity", "entity": {"var": "fireball"}, "property": "IsGrounded", "value": 0 },

    { "op": "CopyPosition", "dst": {"var": "fireball"}, "src": {"self": true} },
    { "op": "MoveForward",  "entity": {"var": "fireball"}, "force": 500 },
    { "op": "PlaySound",    "tag": "SoundLaunch" },

    { "op": "Log", "message": "Fireball: 충돌 대기 중..." },
    { "op": "WaitCollision", "entity": {"var": "fireball"} },
    { "op": "Move", "dst": {"var": "hitTarget"}, "src": "Hit" },

    { "op": "Log", "message": "Fireball: 충돌! 폭발 처리" },

    { "op": "GetPosition", "dst": "R0", "entity": "Spawned" },

    { "op": "DestroyEntity", "entity": {"var": "fireball"} },

    { "op": "ApplyDamageConst", "target": {"var": "hitTarget"}, "amount": 100 },
    { "op": "PlayVFXAttached",  "entity": {"var": "hitTarget"}, "tag": "VFXHit" },

    { "op": "SnippetCheckDeath", "entity": {"var": "hitTarget"}, "deadTag": "StateDead" },

    { "op": "PlayVFX",            "pos": "R0", "tag": "VFXExplode" },
    { "op": "PlaySoundAtLocation","pos": "R0", "tag": "SoundExplode" },

    { "op": "Log", "message": "Fireball: 범위 피해 적용" },

    { "op": "ForEachInRadius", "center": {"var": "hitTarget"}, "radius": 300 },
      { "op": "IfHasTrait", "entity": "Iter", "trait": "Hittable" },
        { "op": "Move",             "dst": {"target": true}, "src": "Iter" },
        { "op": "ApplyDamageConst", "target": {"target": true}, "amount": 50 },
        { "op": "ApplyEffect",      "target": {"target": true}, "effectTag": "EffectBurn" },

        { "op": "SnippetCheckDeath", "entity": {"target": true}, "deadTag": "StateDead" },

      { "op": "EndIf" },
    { "op": "EndForEach" },

    { "op": "RemoveTag", "entity": {"self": true}, "tag": "AnimCast" },

    { "op": "Halt" }
  ]
}
