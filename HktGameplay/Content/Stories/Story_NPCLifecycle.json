{
  "storyTag": "Story.Flow.NPC.Lifecycle",
  "cancelOnDuplicate": false,
  "tags": {
    "StateDead": "State.Dead",
    "AnimDeath": "Anim.FullBody.Action.Death"
  },
  "steps": [
    { "op": "Label", "name": "check" },
    { "op": "HasTag", "dst": "R0", "entity": "Self", "tag": "State.Dead" },
    { "op": "JumpIf", "cond": "R0", "label": "die" },
    { "op": "WaitSeconds", "seconds": 1.0 },
    { "op": "Jump", "label": "check" },

    { "op": "Label", "name": "die" },
    { "op": "Log", "message": "NPC died -- random loot drop" },

    { "op": "LoadConst", "dst": "R0", "value": 4 },
    { "op": "RandomInt", "dst": "R1", "modulus": "R0" },

    { "op": "IfEqConst", "src": "R1", "value": 0 },
      { "op": "Jump", "label": "drop_staff" },
    { "op": "EndIf" },

    { "op": "IfEqConst", "src": "R1", "value": 1 },
      { "op": "Jump", "label": "drop_bandage" },
    { "op": "EndIf" },

    { "op": "IfEqConst", "src": "R1", "value": 2 },
      { "op": "Jump", "label": "drop_hammer" },
    { "op": "EndIf" },

    { "op": "Jump", "label": "drop_wings" },

    { "op": "Label", "name": "drop_staff" },
    { "op": "Log", "message": "[Snippet] SpawnGroundItem" },
    { "op": "SpawnEntity", "classTag": "Entity.Item.AncientStaff" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 200 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "CopyPosition", "dst": "Spawned", "src": "Self" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackPower", "value": 8 },
    { "op": "SetItemSkillTag", "entity": "Spawned", "skillTag": "Story.Event.Combat.UseSkill" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillCPCost", "value": 50 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "RecoveryFrame", "value": 90 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillTargetRequired", "value": 1 },
    { "op": "SetStance", "entity": "Spawned", "stanceTag": "Entity.Stance.Spear" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.AncientStaff" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Skill.Fireball" },
    { "op": "Jump", "label": "after_drop" },

    { "op": "Label", "name": "drop_bandage" },
    { "op": "Log", "message": "[Snippet] SpawnGroundItem" },
    { "op": "SpawnEntity", "classTag": "Entity.Item.Bandage" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 202 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "CopyPosition", "dst": "Spawned", "src": "Self" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackPower", "value": 0 },
    { "op": "SetItemSkillTag", "entity": "Spawned", "skillTag": "Story.Event.Combat.UseSkill" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillCPCost", "value": 40 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "RecoveryFrame", "value": 120 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillTargetRequired", "value": 0 },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.Bandage" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Skill.Heal" },
    { "op": "Jump", "label": "after_drop" },

    { "op": "Label", "name": "drop_hammer" },
    { "op": "Log", "message": "[Snippet] SpawnGroundItem" },
    { "op": "SpawnEntity", "classTag": "Entity.Item.ThunderHammer" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 203 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "CopyPosition", "dst": "Spawned", "src": "Self" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackPower", "value": 12 },
    { "op": "SetItemSkillTag", "entity": "Spawned", "skillTag": "Story.Event.Combat.UseSkill" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillCPCost", "value": 60 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "RecoveryFrame", "value": 100 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillTargetRequired", "value": 1 },
    { "op": "SetStance", "entity": "Spawned", "stanceTag": "Entity.Stance.Sword1H" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.ThunderHammer" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Skill.Lightning" },
    { "op": "Jump", "label": "after_drop" },

    { "op": "Label", "name": "drop_wings" },
    { "op": "Log", "message": "[Snippet] SpawnGroundItem" },
    { "op": "SpawnEntity", "classTag": "Entity.Item.WingsOfFreedom" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemState", "value": 0 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "ItemId", "value": 204 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "EquipIndex", "value": -1 },
    { "op": "CopyPosition", "dst": "Spawned", "src": "Self" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "AttackPower", "value": 0 },
    { "op": "SetItemSkillTag", "entity": "Spawned", "skillTag": "Story.Event.Combat.UseSkill" },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillCPCost", "value": 30 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "RecoveryFrame", "value": 150 },
    { "op": "SaveConstEntity", "entity": "Spawned", "property": "SkillTargetRequired", "value": 0 },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Item.WingsOfFreedom" },
    { "op": "AddTag", "entity": "Spawned", "tag": "Entity.Attr.Skill.Buff" },

    { "op": "Label", "name": "after_drop" },
    { "op": "AddTag", "entity": "Self", "tag": "Anim.FullBody.Action.Death" },
    { "op": "WaitSeconds", "seconds": 3.0 },
    { "op": "DestroyEntity", "entity": "Self" },
    { "op": "Halt" }
  ]
}
