# HktAutomationTests CLI Runner 설정
#
# 사용법:
#   1. 이 파일을 같은 폴더에 `.hkt-test.env` 로 복사
#   2. 자신의 환경에 맞게 두 경로를 수정
#   3. `python run_automation_tests.py` 실행
#
# 둘 다 설정하지 않으면 환경변수(UE_ENGINE_PATH, UE_PROJECT_FILE) 또는
# CLI 인자(--engine, --uproject)로도 대체 가능.

# UE5.6 엔진이 설치된 루트 경로 (Engine/ 폴더의 부모)
# 예: Windows
#   UE_ENGINE_PATH=C:/Program Files/Epic Games/UE_5.6
# 예: Linux
#   UE_ENGINE_PATH=/opt/UnrealEngine_5.6
UE_ENGINE_PATH=

# 호스트 UE 프로젝트의 .uproject 파일 절대 경로
# 예: D:/Projects/HktProto/HktProto.uproject
UE_PROJECT_FILE=

# (선택) 기본 테스트 필터 prefix.
# - 비워두면 `HktCore` 가 사용됨 (HktAutomationTests + HktCore Tests 모두 포함)
# - 특정 카테고리만: `HktCore.Story` / `HktCore.VM` 등
HKT_TEST_FILTER=
